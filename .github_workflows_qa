name: Public Readiness Kit QA

on:
  push:
  pull_request:

permissions:
  contents: read

jobs:
  qa:
    runs-on: ubuntu-latest
    env:
      PYTHONDONTWRITEBYTECODE: "1"
    steps:
      - uses: actions/checkout@v4
      - name: Show Python version
        run: python3 --version
      - name: Run public preflight
        run: make preflight
